{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trial.schema.json",
  "title": "Trial",
  "description": "A clinical trial evaluating one or more therapies in one or more conditions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "name", "conditions", "therapies", "resultStatus", "curation"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^trial-[a-z0-9-]+$",
      "description": "Stable kebab-case id prefixed with 'trial-'."
    },
    "type": { "const": "trial" },
    "name": { "type": "string", "minLength": 1 },
    "nctId": {
      "type": "string",
      "pattern": "^NCT[0-9]{8}$",
      "description": "ClinicalTrials.gov identifier; used to build a deep link."
    },
    "phase": { "type": "string", "description": "e.g. 'Phase 3', 'Pivotal RCT', 'Registry'." },
    "status": { "enum": ["recruiting", "active", "completed", "terminated", "unknown"] },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^cond-[a-z0-9-]+$" }
    },
    "therapies": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^(rx|dev|dig|proc)-[a-z0-9-]+$" }
    },
    "enrollment": { "type": "integer", "minimum": 0 },
    "year": { "type": "integer", "description": "Year of primary publication / key readout." },
    "primaryEndpoint": { "type": "string" },
    "outcomeSummary": { "type": "string" },
    "resultStatus": { "enum": ["positive", "mixed", "negative", "ongoing", "terminated"] },
    "references": {
      "type": "array",
      "items": { "type": "string" },
      "description": "URLs or 'PMID:########' citations."
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        }
      },
      "description": "External info links shown in the detail panel. For trials: a source that summarizes the outcomes OTHER than ClinicalTrials.gov (journal article, TCTMD/medical news, society guideline). Each item is {label, url}."
    },
    "timeline": { "$ref": "#/definitions/timeline" },
    "pulse": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Newsworthiness / attention score, 0-10 (10 = most recent coverage). Maintained by the update routine; drives label font size in the graph. Omit if unscored."
    },
    "curation": { "$ref": "#/definitions/curation" }
  },
  "definitions": {
    "curation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "lastUpdated"],
      "properties": {
        "status": { "enum": ["draft", "curated"] },
        "lastUpdated": { "type": "string", "format": "date" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "event", "dateBasis", "precision"],
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "ISO date used for timeline placement. If precision is year or month, use the first day of the placeholder period."
        },
        "event": { "type": "string", "minLength": 1 },
        "dateBasis": {
          "enum": ["fda-approval", "ce-mark", "availability-announcement", "trial-start"]
        },
        "precision": { "enum": ["day", "month", "year"] },
        "source": { "type": "string", "format": "uri" },
        "notes": { "type": "string" }
      }
    }
  }
}
