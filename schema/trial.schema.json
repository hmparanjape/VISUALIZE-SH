{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trial.schema.json",
  "title": "Trial",
  "description": "A clinical trial evaluating one or more therapies in one or more conditions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "name", "conditions", "therapies", "resultStatus", "curation"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^trial-[a-z0-9-]+$",
      "description": "Stable kebab-case id prefixed with 'trial-'."
    },
    "type": { "const": "trial" },
    "name": { "type": "string", "minLength": 1 },
    "nctId": {
      "type": "string",
      "pattern": "^NCT[0-9]{8}$",
      "description": "ClinicalTrials.gov identifier; used to build a deep link."
    },
    "phase": { "type": "string", "description": "e.g. 'Phase 3', 'Pivotal RCT', 'Registry'." },
    "status": { "enum": ["recruiting", "active", "completed", "terminated", "unknown"] },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^cond-[a-z0-9-]+$" }
    },
    "therapies": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^(rx|dev|dig|proc)-[a-z0-9-]+$" }
    },
    "enrollment": { "type": "integer", "minimum": 0 },
    "year": { "type": "integer", "description": "Year of primary publication / key readout." },
    "primaryEndpoint": { "type": "string" },
    "outcomeSummary": { "type": "string" },
    "resultStatus": { "enum": ["positive", "mixed", "negative", "ongoing", "terminated"] },
    "references": {
      "type": "array",
      "items": { "type": "string" },
      "description": "URLs or 'PMID:########' citations."
    },
    "pulse": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Newsworthiness / attention score, 0-10 (10 = most recent coverage). Maintained by the update routine; drives label font size in the graph. Omit if unscored."
    },
    "curation": { "$ref": "#/definitions/curation" }
  },
  "definitions": {
    "curation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "lastUpdated"],
      "properties": {
        "status": { "enum": ["draft", "curated"] },
        "lastUpdated": { "type": "string", "format": "date" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    }
  }
}
